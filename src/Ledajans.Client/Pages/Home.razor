@page "/"
@attribute [Authorize]
@implements IAsyncDisposable
@inject AttendanceService AttendanceService
@inject GeofenceService GeofenceService
@inject GeolocationService GeolocationService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Geldim - Ledajans</PageTitle>

<div class="page-header text-center mb-2">
    <MudText Typo="Typo.h5">Geldim</MudText>
    <div class="subtitle">Ofis alanı içindeyken giriş ve çıkışınızı işaretleyin</div>
</div>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="10" md="8" lg="7">
        <MudPaper Class="ledajans-card ledajans-card-accent" Elevation="0">
            <div class="checkin-hero">
                @if (_loadingStatus)
                {
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="my-8" />
                }
                else if (_hasCheckedIn && _hasCheckedOut)
                {
                    <div class="checkin-icon-wrap success">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:3.5rem;" />
                    </div>
                    <MudText Typo="Typo.h5" Style="font-weight:700;">Bugün tamamlandı ✓</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">
                        Giriş: @TurkishFormat.FormatDateTime(_checkInLocal)
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        Çıkış: @TurkishFormat.FormatDateTime(_checkOutLocal)
                    </MudText>
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small" Class="mt-4">
                        Gün kaydı tamam
                    </MudChip>
                }
                else if (_hasCheckedIn)
                {
                    <div class="checkin-icon-wrap success">
                        <MudIcon Icon="@Icons.Material.Filled.Login" Color="Color.Success" Style="font-size:3.5rem;" />
                    </div>
                    <MudText Typo="Typo.h5" Style="font-weight:700;">Bugün geldiniz ✓</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary mt-2 mb-3">
                        Giriş: @TurkishFormat.FormatDateTime(_checkInLocal)
                    </MudText>

                    @if (_loadingLocation)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">Konum alınıyor...</MudText>
                    }
                    else if (_distanceMeters is not null && _geofence is not null)
                    {
                        <MudAlert Severity="@_distanceSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-4 text-left">
                            <strong>@_geofence.Name</strong><br />
                            Ofise yaklaşık <strong>@Math.Round(_distanceMeters.Value) m</strong> uzaktasınız.
                            @if (_userAccuracy is not null)
                            {
                                <span> (hassasiyet ±@Math.Round(_userAccuracy.Value) m)</span>
                            }
                            @if (_withinRadius)
                            {
                                <span> Çıkış işaretleyebilirsiniz.</span>
                            }
                            else
                            {
                                <span> Alan dışında görünüyorsunuz.</span>
                            }
                        </MudAlert>
                    }

                    @if (!string.IsNullOrEmpty(_locationHint))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">@_locationHint</MudText>
                    }

                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.MyLocation" OnClick="() => RefreshDistance(true)"
                               Disabled="_loadingLocation" Class="mb-3">
                        Konumu güncelle
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Logout" Disabled="_processingCheckout"
                               OnClick="HandleCheckOut" Class="checkin-btn">
                        @if (_processingCheckout)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span>GPS sabitleniyor...</span>
                        }
                        else
                        {
                            <span>ÇIKIŞ YAPTIM</span>
                        }
                    </MudButton>

                    @if (!string.IsNullOrEmpty(_message))
                    {
                        <MudAlert Severity="@_severity" Class="mt-5" Variant="Variant.Outlined" Dense="true">@_message</MudAlert>
                    }
                }
                else
                {
                    <div class="checkin-icon-wrap">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Style="font-size:3.5rem;" />
                    </div>
                    <MudText Typo="Typo.h5" Style="font-weight:700;">Henüz işaretlemediniz</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2 mb-3">
                        Konum izni vererek ofis sınırı içindeyken butona basın.
                    </MudText>

                    @if (_loadingLocation)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">Konum alınıyor...</MudText>
                    }
                    else if (_distanceMeters is not null && _geofence is not null)
                    {
                        <MudAlert Severity="@_distanceSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-4 text-left">
                            <strong>@_geofence.Name</strong><br />
                            Ofise yaklaşık <strong>@Math.Round(_distanceMeters.Value) m</strong> uzaktasınız.
                            @if (_userAccuracy is not null)
                            {
                                <span> (hassasiyet ±@Math.Round(_userAccuracy.Value) m)</span>
                            }
                            @if (_withinRadius)
                            {
                                <span> Giriş yapabilirsiniz.</span>
                            }
                            else
                            {
                                <span> Alan dışında görünüyorsunuz.</span>
                            }
                        </MudAlert>
                    }

                    @if (!string.IsNullOrEmpty(_locationHint))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">@_locationHint</MudText>
                    }

                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.MyLocation" OnClick="() => RefreshDistance(true)"
                               Disabled="_loadingLocation" Class="mb-3">
                        Konumu güncelle
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.TouchApp" Disabled="_processing"
                               OnClick="HandleCheckIn" Class="checkin-btn">
                        @if (_processing)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                            <span>GPS sabitleniyor...</span>
                        }
                        else
                        {
                            <span>GELDİM</span>
                        }
                    </MudButton>

                    @if (!string.IsNullOrEmpty(_message))
                    {
                        <MudAlert Severity="@_severity" Class="mt-5" Variant="Variant.Outlined" Dense="true">@_message</MudAlert>
                    }
                }
            </div>
        </MudPaper>

        @if (_showLocationMap)
        {
            <ErrorBoundary>
                <ChildContent>
                    <MudPaper Elevation="0" Class="ledajans-card pa-2 mt-3 employee-location-card">
                        <div class="employee-location-legend">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="employee-legend-office">
                                Ofis alanı
                            </MudChip>
                            @if (_userLat is not null)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_withinRadius ? Color.Success : Color.Error)">
                                    @(_withinRadius ? "Alan içindesiniz" : "Alan dışındasınız")
                                </MudChip>
                                @if (_userAccuracy is not null)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary align-self-center">
                                        Hassasiyet: ±@Math.Round(_userAccuracy.Value) m
                                    </MudText>
                                }
                            }
                            else if (_loadingLocation)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Konum alınıyor...</MudText>
                            }
                        </div>
                        <div id="@MapElementId" class="employee-location-map"></div>
                    </MudPaper>
                </ChildContent>
                <ErrorContent>
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-3">
                        Konum haritası yüklenemedi. Giriş/çıkış yine de çalışır.
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        }

        <MudText Typo="Typo.caption" Align="Align.Center" Class="d-block mt-4 mud-text-secondary">
            Konum doğrulaması güvenlik için sunucu tarafında yapılır.
        </MudText>
    </MudItem>
</MudGrid>

@code {
    private const string MapElementId = "employeeLocationMap";

    private bool _loadingStatus = true;
    private bool _loadingLocation;
    private bool _processing;
    private bool _processingCheckout;
    private bool _hasCheckedIn;
    private bool _hasCheckedOut;
    private bool _withinRadius;
    private bool _mapReady;
    private bool _mapInitTried;
    private bool _mapUnavailable;
    private bool _disposed;
    private double? _distanceMeters;
    private double? _userLat;
    private double? _userLng;
    private double? _userAccuracy;
    private GeofenceDto? _geofence;
    private DateTime? _checkInLocal;
    private DateTime? _checkOutLocal;
    private string? _message;
    private string? _locationHint;
    private Severity _severity = Severity.Info;
    private Severity _distanceSeverity = Severity.Info;

    private bool _showLocationMap => !_loadingStatus && !_hasCheckedOut && _geofence is not null && !_mapUnavailable;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            if (state.User.IsInRole(Roles.Admin))
            {
                Navigation.NavigateTo("admin/users", replace: true);
                return;
            }

            _geofence = await GeofenceService.GetAsync();
            await LoadStatus();
            if (!_hasCheckedOut)
                _ = LoadLocationInBackground();
        }
        catch (Exception)
        {
            _message = "Sayfa yüklenemedi. Sayfayı yenileyip tekrar deneyin.";
            _severity = Severity.Error;
            _loadingStatus = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed) return;

        if (!_showLocationMap)
        {
            await DestroyMapAsync();
            return;
        }

        if (_mapReady || _mapInitTried || _geofence is null || _loadingStatus)
            return;

        _mapInitTried = true;
        try
        {
            await Task.Yield();
            if (_disposed) return;

            var ok = await JS.InvokeAsync<bool>("ledajansLocationMap.init",
                MapElementId, _geofence.Latitude, _geofence.Longitude, _geofence.RadiusMeters);
            if (!ok)
            {
                _mapUnavailable = true;
                await InvokeAsync(StateHasChanged);
                return;
            }

            _mapReady = true;
            if (_userLat is not null && _userLng is not null)
                await SyncMapUserAsync();
        }
        catch
        {
            _mapReady = false;
            _mapUnavailable = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        await DestroyMapAsync();
    }

    private async Task DestroyMapAsync()
    {
        if (!_mapReady) return;
        try
        {
            await JS.InvokeVoidAsync("ledajansLocationMap.destroy", MapElementId);
        }
        catch
        {
            // sayfa kapanırken JS interop hata verebilir
        }
        _mapReady = false;
    }

    private async Task SyncMapUserAsync()
    {
        if (!_mapReady || _userLat is null || _userLng is null) return;
        try
        {
            await JS.InvokeVoidAsync("ledajansLocationMap.updateUser",
                MapElementId, _userLat.Value, _userLng.Value, _userAccuracy ?? 0, _withinRadius);
        }
        catch
        {
            // harita senkronu başarısız olsa da uygulama çalışmaya devam etsin
        }
    }

    private async Task LoadStatus()
    {
        _loadingStatus = true;
        _message = null;
        try
        {
            var status = await AttendanceService.GetTodayAsync();
            _hasCheckedIn = status.HasCheckedIn;
            _hasCheckedOut = status.HasCheckedOut;
            _checkInLocal = status.CheckInUtc?.AddHours(3);
            _checkOutLocal = status.CheckOutUtc?.AddHours(3);
        }
        catch
        {
            _message = "Durum yüklenemedi. İnternet bağlantınızı kontrol edip yenileyin.";
            _severity = Severity.Error;
        }
        finally
        {
            _loadingStatus = false;
            StateHasChanged();
        }
    }

    private async Task LoadLocationInBackground()
    {
        await Task.Delay(400);
        await RefreshDistance();
    }

    private async Task RefreshDistance(bool userInitiated = false)
    {
        _loadingLocation = true;
        if (userInitiated) _message = null;
        try
        {
            _geofence ??= await GeofenceService.GetAsync();
            if (_geofence is null)
            {
                _message = "Ofis konumu tanımlı değil. Yöneticinize başvurun.";
                _severity = Severity.Warning;
                return;
            }

            var pos = await GeolocationService.GetPreviewPositionAsync();
            ApplyPosition(pos);
            _locationHint = pos.LowAccuracy
                ? $"GPS hassasiyeti düşük (±{Math.Round(pos.Accuracy)} m). Pencere kenarında bekleyin."
                : null;
            await SyncMapUserAsync();
        }
        catch (JSException ex)
        {
            if (userInitiated)
            {
                _message = ex.Message;
                _severity = Severity.Warning;
            }
            else
                _locationHint = "Konum önizlemesi şu an alınamadı. GELDİM ile tekrar deneyebilirsiniz.";
        }
        catch (Exception)
        {
            if (userInitiated)
            {
                _message = "Konum bilgisi alınamadı. Tekrar deneyin.";
                _severity = Severity.Warning;
            }
        }
        finally
        {
            _loadingLocation = false;
            StateHasChanged();
        }
    }

    private void ApplyPosition(GeoPosition pos)
    {
        if (_geofence is null) return;

        _userLat = pos.Latitude;
        _userLng = pos.Longitude;
        _userAccuracy = pos.Accuracy;
        _distanceMeters = GeoHelper.DistanceMeters(
            _geofence.Latitude, _geofence.Longitude,
            pos.Latitude, pos.Longitude);
        _withinRadius = GeoHelper.IsWithinGeofence(_distanceMeters.Value, pos.Accuracy, _geofence.RadiusMeters);
        var worstCase = _distanceMeters.Value + pos.Accuracy;
        _distanceSeverity = _withinRadius ? Severity.Success
            : worstCase <= _geofence.RadiusMeters * 1.5 ? Severity.Warning
            : Severity.Error;
    }

    private async Task<GeoPosition> ResolveCheckInPositionAsync()
    {
        if (_userLat is not null && _userLng is not null && _userAccuracy is not null)
            return new GeoPosition(_userLat.Value, _userLng.Value, _userAccuracy.Value);

        return await GeolocationService.GetCheckInPositionAsync();
    }

    private async Task HandleCheckIn()
    {
        _processing = true;
        _message = null;
        try
        {
            var pos = await ResolveCheckInPositionAsync();
            var result = await AttendanceService.CheckInAsync(new CheckInRequest
            {
                Latitude = pos.Latitude,
                Longitude = pos.Longitude,
                Accuracy = pos.Accuracy
            });

            _message = result.Message;
            _severity = result.Success ? Severity.Success : Severity.Warning;

            if (result.Success || result.Message.Contains("zaten", StringComparison.OrdinalIgnoreCase))
            {
                if (result.Success)
                    Snackbar.Add("Geldiğiniz kaydedildi.", Severity.Success);
                await LoadStatus();
                if (result.Success)
                    await RefreshDistance();
            }
            else
            {
                await RefreshDistance();
            }
        }
        catch (JSException ex)
        {
            _message = ex.Message;
            _severity = Severity.Error;
        }
        catch (Exception)
        {
            _message = "Beklenmeyen bir hata oluştu. Tekrar deneyin.";
            _severity = Severity.Error;
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task HandleCheckOut()
    {
        _processingCheckout = true;
        _message = null;
        try
        {
            var pos = await ResolveCheckInPositionAsync();
            var result = await AttendanceService.CheckOutAsync(new CheckInRequest
            {
                Latitude = pos.Latitude,
                Longitude = pos.Longitude,
                Accuracy = pos.Accuracy
            });

            _message = result.Message;
            _severity = result.Success ? Severity.Success : Severity.Warning;

            if (result.Success)
            {
                Snackbar.Add("Çıkışınız kaydedildi.", Severity.Success);
                await LoadStatus();
            }
            else
            {
                await RefreshDistance();
            }
        }
        catch (JSException ex)
        {
            _message = ex.Message;
            _severity = Severity.Error;
        }
        catch (Exception)
        {
            _message = "Beklenmeyen bir hata oluştu. Tekrar deneyin.";
            _severity = Severity.Error;
        }
        finally
        {
            _processingCheckout = false;
        }
    }
}
