@page "/gecmisim"
@attribute [Authorize]
@inject AttendanceService AttendanceService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Giriş - Çıkış İşlemlerim - Ledajans</PageTitle>

<div class="page-header">
    <MudText Typo="Typo.h5">Giriş - Çıkış İşlemlerim</MudText>
    <div class="subtitle">Ofis giriş ve çıkış kayıtlarınız</div>
</div>

<MudPaper Class="ledajans-card pa-4" Elevation="0">
    @if (_loading)
    {
        <div class="text-center py-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_items.Count == 0)
    {
        <div class="history-empty">
            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Style="font-size:3rem;color:#f46f2c;opacity:0.5;" Class="mb-3" />
            <MudText Typo="Typo.body1">Henüz kayıt yok</MudText>
            <MudText Typo="Typo.caption" Class="mt-1">İlk kaydınızı "Geldim" sayfasından yapabilirsiniz.</MudText>
        </div>
    }
    else
    {
        <MudText Typo="Typo.caption" Class="mb-3 mud-text-secondary">
            Toplam @_items.Count kayıt
        </MudText>

        @foreach (var item in _items)
        {
            <div class="history-item">
                <div class="history-date-badge">
                    <span class="day">@item.LocalDate.Day</span>
                    <span class="month">@TurkishFormat.FormatDate(item.LocalDate, "MMM")</span>
                </div>
                <div class="flex-grow-1">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">
                        @TurkishFormat.FormatDate(item.LocalDate, "dddd, dd MMMM yyyy")
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Small" Class="mr-1" Style="vertical-align:-2px;" />
                        Giriş: @TurkishFormat.FormatTimeLocal(item.CheckInUtc)
                    </MudText>
                    @if (item.CheckOutUtc is not null)
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Class="mr-1" Style="vertical-align:-2px;" />
                            Çıkış: @TurkishFormat.FormatTimeLocal(item.CheckOutUtc.Value)
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="mt-1 mud-text-secondary">Çıkış henüz işaretlenmedi</MudText>
                    }
                </div>
                <div class="d-flex flex-column align-end gap-1">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@(item.CheckOutUtc is not null ? Color.Success : Color.Primary)">
                        @(item.CheckOutUtc is not null ? "Tamamlandı" : "Yalnızca giriş")
                    </MudChip>
                    @if (item.IsLate)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning">
                            Geç kaldı
                        </MudChip>
                    }
                </div>
            </div>
        }
    }
</MudPaper>

@code {
    private List<MyAttendanceHistoryItem> _items = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            if (state.User.IsInRole(Roles.Admin))
            {
                Navigation.NavigateTo("admin/users", replace: true);
                return;
            }

            _items = await AttendanceService.GetMyHistoryAsync();
        }
        catch
        {
            _items = new();
        }
        finally
        {
            _loading = false;
        }
    }
}
