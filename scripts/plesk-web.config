<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules>
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\Ledajans.Server.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="OutOfProcess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Natro Plesk: asagidaki degerleri doldurun -->
          <environmentVariable name="ConnectionStrings__DefaultConnection" value="Server=localhost;Port=3306;Database=VERITABANI;User=KULLANICI;Password=SIFRE;" />
          <environmentVariable name="Jwt__Key" value="BURAYA_EN_AZ_32_KARAKTER_GUVENLI_ANAHTAR" />
          <environmentVariable name="Seed__AdminPassword" value="GUVENLI_ADMIN_SIFRESI" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
